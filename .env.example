# Cloudflare R2 public base URL for audio assets
NEXT_PUBLIC_R2_BASE=https://pub-b645bb3d6f0e4603b252db4c142a9f8f.r2.dev

# Sentry DSN for error tracking (leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=

# Environment: development | production
NODE_ENV=development

# Stripe — dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # Stripe publishable key — safe to expose client-side
STRIPE_SECRET_KEY= # Stripe secret key — server-side only, never expose client-side
STRIPE_WEBHOOK_SECRET= # Stripe webhook signing secret — verify webhook authenticity
STRIPE_FOUNDING_ARTIST_PRICE_ID= # Price ID for $149 Founding Artist one-time product
STRIPE_PRO_MONTHLY_PRICE_ID= # Price ID for $12/month Pro subscription
STRIPE_PRO_ANNUAL_PRICE_ID= # Price ID for $10/month annual Pro subscription

# App
NEXT_PUBLIC_APP_URL= # Full deployment URL e.g. https://elevare-scribe.vercel.app

# Supabase — supabase.com
NEXT_PUBLIC_SUPABASE_URL= # Supabase project URL
SUPABASE_SERVICE_ROLE_KEY= # Supabase service role key — server-side only, never expose
